<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyGoodDiary.src.View.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:calendar="clr-namespace:Plugin.Maui.Calendar.Controls;assembly=Plugin.Maui.Calendar"
    Title="Mi Calendario">
    <VerticalStackLayout
        Padding="30"
        HorizontalOptions="Center"
        Spacing="25"
        VerticalOptions="Center">

        <Label
            FontAttributes="Bold"
            FontSize="24"
            HorizontalOptions="Center"
            Text="Mi calendario"
            TextColor="Black" />

        <Border
            Padding="20"
            BackgroundColor="#F9F9F9"
            Stroke="#D0D0D0"
            StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">

                <calendar:Calendar
                    x:Name="CalendarioCustom"
                    UseAbbreviatedDayNames="True"
                    Padding="10"               
                    DaysTitleLabelFirstUpperRestLower="True"
                    SelectedDate="{Binding FechaSeleccionada}"
                    SelectedDayBackgroundColor="#512BD4"
                    SelectedDayTextColor="White" 
                    />
                    

                <BoxView
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Color="Black" />

                <Label
                    FontAttributes="Italic"
                    HorizontalOptions="Center"
                    Text="{Binding FechaSeleccionada, StringFormat='Has elegido: {0:dd MMMM yyyy}'}"
                    TextColor="Black" />

            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentPage>
